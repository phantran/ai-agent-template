OPENAI_API_KEY=
GROQ_API_KEY=
AI_AGENT_ENVIRONMENT=local
AI_AGENT_LOG_LEVEL=INFO
AI_AGENT_SERVICE_NAME=ai-agent-template
AI_AGENT_MODEL_PROVIDER=groq
AI_AGENT_MODEL_NAME=llama-3.1-8b-instant
AI_AGENT_MODEL_TEMPERATURE=0
AI_AGENT_CORS_ALLOWED_ORIGINS=["http://localhost:5173","http://127.0.0.1:5173","http://localhost:5174","http://127.0.0.1:5174"]
AI_AGENT_RAG_ENABLED=true
AI_AGENT_RAG_COLLECTION_NAME=agent_knowledge
AI_AGENT_RAG_TOP_K=4
AI_AGENT_RAG_VOICE_TOP_K=4
AI_AGENT_RAG_CHUNK_SIZE=1000
AI_AGENT_RAG_CHUNK_OVERLAP=150
AI_AGENT_RAG_EMBEDDING_MODEL_NAME=BAAI/bge-small-en-v1.5
AI_AGENT_RAG_EMBEDDING_DIMENSIONS=384
AI_AGENT_QDRANT_URL=http://localhost:6333
AI_AGENT_QDRANT_STORAGE_PATH=.qdrant
QDRANT_API_KEY=
AI_AGENT_OTEL_ENABLED=false
AI_AGENT_OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317

# Auth: comma-list of allowed API keys. Empty = auth disabled.
AI_AGENT_AUTH_API_KEYS=[]
AI_AGENT_RATE_LIMIT_ENABLED=true
AI_AGENT_RATE_LIMIT_REQUESTS=60
AI_AGENT_RATE_LIMIT_WINDOW_SECONDS=60
AI_AGENT_REQUEST_MAX_BODY_BYTES=5242880

# memory = in-process LangGraph checkpointer (thread-id memory across calls).
# none = no checkpointer.
AI_AGENT_AGENT_CHECKPOINT_BACKEND=memory

AI_AGENT_RAG_SEARCH_MULTIPLIER=3
